# Biến môi trường FE — Vite chỉ đưa các biến tiền tố VITE_ vào client bundle.
# LƯU Ý: giá trị ở đây là PUBLIC (nằm trong JS gửi tới browser) — không bao giờ đặt secret.
VITE_API_URL=http://localhost:3000/api
# Google OAuth (Phase 9, D60) — DÁN CÙNG Client ID đã đặt ở backend GOOGLE_CLIENT_ID.
# Lấy ở Google Cloud Console > Credentials > OAuth client ID (Web).
VITE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
