# ===== Server =====
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
# trust proxy cho express-rate-limit lấy đúng IP client khi chạy SAU reverse proxy
# (Render/Railway/Nginx). Số = số hop tin tưởng (vd 1). Đặt 0 nếu Node bị expose TRỰC TIẾP
# (không có proxy) để attacker không giả X-Forwarded-For né rate-limit. Bỏ trống = tự suy theo
# NODE_ENV (production → 1, dev → 0).
TRUST_PROXY=

# ===== Database — Neon Postgres =====
# Copy connection string từ Neon dashboard (Connect > Connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ===== Auth =====
# BẮT BUỘC đặt: chuỗi ngẫu nhiên ≥ 32 ký tự để ký JWT — tạo bằng:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Server TỪ CHỐI khởi động nếu để trống / dùng giá trị mẫu / (production) ngắn hơn 32 ký tự.
JWT_SECRET=
# Thời gian sống của token. Token lưu ở localStorage nên TTL ngắn hơn = an toàn hơn nếu bị lộ
# (đánh đổi: user phải đăng nhập lại sớm hơn). Đổi/đặt lại mật khẩu đã vô hiệu token cũ ngay.
JWT_EXPIRES_IN=7d

# ===== Seed (npx prisma db seed) =====
# Dev: bỏ trống SEED_ADMIN_PASSWORD thì dùng mặc định admin@bookstore.vn / Admin@123 (tiện local).
# PRODUCTION (NODE_ENV=production): BẮT BUỘC đặt SEED_ADMIN_PASSWORD mạnh (>= 8 ký tự, khác
# Admin@123) — nếu không seed sẽ TỪ CHỐI chạy. Khi ĐÃ đặt env này, chạy lại seed sẽ CẬP NHẬT
# mật khẩu admin (đổi password rồi seed lại là đổi thật, không kẹt hash cũ).
SEED_ADMIN_EMAIL=admin@bookstore.vn
SEED_ADMIN_PASSWORD=
# Dữ liệu demo (khách mẫu Demo@123 + đơn + review cho dashboard). CHỈ seed khi =true và KHÔNG
# ở production. Để trống / không phải "true" thì bỏ qua (an toàn cho môi trường công khai).
SEED_DEMO_DATA=true

# ===== Google OAuth (Phase 9, D60 — đăng nhập bằng Google) =====
# Google Cloud Console > APIs & Services > Credentials > Create OAuth client ID (Web).
# Authorized JavaScript origins: http://localhost:5173 (FE). KHÔNG cần redirect URI
# (dùng Google Identity Services token flow, không phải redirect). Dán đúng Client ID này
# vào CẢ backend (GOOGLE_CLIENT_ID) lẫn frontend (VITE_GOOGLE_CLIENT_ID).
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# ===== Cloudinary (ảnh bìa sách — D15) =====
# Copy "API environment variable" trong Cloudinary Console > Settings > API Keys
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ===== VNPay sandbox (Phase 5 — đăng ký tại https://sandbox.vnpayment.vn) =====
# VNPAY gửi qua email sau khi đăng ký Merchant môi trường TEST
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Return URL trỏ về BACKEND (không phải FE): backend verify chữ ký rồi mới redirect FE.
# Khi deploy đổi localhost thành domain công khai (VNPay cần URL public cho IPN — D18)
VNP_RETURN_URL=http://localhost:3000/api/payments/vnpay/return

# ===== Email (Resend — Phase 6, D50) =====
# Tạo tài khoản tại https://resend.com → API Keys → tạo key (dạng "re_...")
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Người gửi: mặc định domain test của Resend (CHỈ giao tới email chủ tài khoản Resend).
# Có domain riêng đã xác minh thì đổi thành "BookStore <no-reply@tenmiencuaban.com>"
MAIL_FROM="BookStore <onboarding@resend.dev>"
# (Tùy chọn) Email nhận khi chạy smoke test: npx tsx scripts/smoke-mailer.ts
SMOKE_TEST_TO=

# ===== Chatbot DeepSeek (Phase 11 — trợ lý tư vấn sách) =====
# Đăng ký tại https://platform.deepseek.com → API Keys → tạo key (dạng "sk-...").
# Nạp vài USD là đủ cho demo. Key CHỈ để ở backend, FE không bao giờ thấy.
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# Đổi model 1 chỗ không phải sửa code. v4-flash: rẻ/nhanh, đủ cho tư vấn sách.
DEEPSEEK_MODEL=deepseek-v4-flash
