# ===== Server =====
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173

# ===== Database — Neon Postgres =====
# Copy connection string từ Neon dashboard (Connect > Connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ===== Auth =====
# Chuỗi ngẫu nhiên ≥ 32 bytes để ký JWT — tạo bằng:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=thay-bang-chuoi-ngau-nhien-dai
JWT_EXPIRES_IN=7d

# ===== Seed (npx prisma db seed) =====
# Không đặt thì seed dùng mặc định admin@bookstore.vn / Admin@123 — PHẢI đổi trước khi deploy
SEED_ADMIN_EMAIL=admin@bookstore.vn
SEED_ADMIN_PASSWORD=Admin@123

# ===== Cloudinary (ảnh bìa sách — D15) =====
# Copy "API environment variable" trong Cloudinary Console > Settings > API Keys
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ===== VNPay sandbox (Phase 5 — đăng ký tại https://sandbox.vnpayment.vn) =====
# VNPAY gửi qua email sau khi đăng ký Merchant môi trường TEST
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Return URL trỏ về BACKEND (không phải FE): backend verify chữ ký rồi mới redirect FE.
# Khi deploy đổi localhost thành domain công khai (VNPay cần URL public cho IPN — D18)
VNP_RETURN_URL=http://localhost:3000/api/payments/vnpay/return

# ===== Email (Resend — Phase 6, D50) =====
# Tạo tài khoản tại https://resend.com → API Keys → tạo key (dạng "re_...")
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Người gửi: mặc định domain test của Resend (CHỈ giao tới email chủ tài khoản Resend).
# Có domain riêng đã xác minh thì đổi thành "BookStore <no-reply@tenmiencuaban.com>"
MAIL_FROM="BookStore <onboarding@resend.dev>"
# (Tùy chọn) Email nhận khi chạy smoke test: npx tsx scripts/smoke-mailer.ts
SMOKE_TEST_TO=
